# Wallet service - optional overrides.
# Defaults in docker-compose.yml are fine for most setups.

# WALLET_DATA_PATH=/data
# WALLET_BACKUP_PATH=/backup
# WALLET_CONSOLE_URL=https://raw.githubusercontent.com/Jdoink/sovereignty_stack/main/command-center-web3/console.html

# OPTIONAL: free Alchemy API key for full asset-change simulation.
# Without it, simulation still does revert detection + calldata decoding.
# WALLET_ALCHEMY_KEY=your_key_here

# OPTIONAL: comma-separated custom RPCs (replace the public defaults).
# WALLET_RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/your_key
# WALLET_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/your_key
